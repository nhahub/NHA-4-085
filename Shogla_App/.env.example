# Copy this file to .env for local development (`cp .env.example .env`).
# On Vercel, set these under Project Settings → Environment Variables instead.

# ---- Supabase (Google sign-in) ----
# Project Settings → API in the Supabase dashboard.
# Server-side (used in server functions, no VITE_ prefix so it's never bundled to the client):
SUPABASE_URL=https://hdxaksoxhyfzbmrehyni.supabase.co
SUPABASE_ANON_KEY=sb_publishable_pVJeNLxx-QQnD-kp2aw4dw_PwktMhzO
# Client-side (same values, exposed to the browser bundle — this is expected,
# the anon key is safe to expose and is meant for this):
VITE_SUPABASE_URL=https://hdxaksoxhyfzbmrehyni.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_pVJeNLxx-QQnD-kp2aw4dw_PwktMhzO

# ---- Databricks (sole source of jobs data) ----
# Workspace hostname WITHOUT the https:// scheme, e.g. dbc-a1b2c3d4-e5f6.cloud.databricks.com
DATABRICKS_HOST=dbc-0bfd27a6-f834.cloud.databricks.com
# A personal access token or OAuth service-principal token with CAN USE on the warehouse
# and SELECT on the jobs table/schema.
DATABRICKS_TOKEN=0af3821b641d74880aa62795ebe7356eac92ec7287a0863d43aba5874c0efcd5
# Optional overrides (defaults are baked into src/lib/jobs.functions.ts):
# DATABRICKS_WAREHOUSE_ID=0e86ac33271557a8
# DATABRICKS_JOBS_TABLE=depi_project.philo_files.gold_jobs

# ---- Supabase Service Role (optional, for storage admin ops) ----
# Project Settings → API → service_role key. Keep this secret, never expose to browser.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_tuuejNVT-ug3iDRD5q_RDA_p3MUaPhh

# ---- CV extraction ----
# No API key needed — CV text is extracted locally with pdf-parse (PDF) and
# mammoth (DOCX), then parsed into skills/experience via keyword matching
# in src/lib/cv-extract.ts.
